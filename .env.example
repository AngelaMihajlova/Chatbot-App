# ── App ────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Superadmin (seeded on first boot) ─────────────────────────────────────────
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=changeme
SUPERADMIN_USERNAME=superadmin

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── PostgreSQL (overridden in docker-compose for container networking) ──────────
DATABASE_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot

# ── Qdrant (overridden in docker-compose) ──────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents

# ── MinIO / S3 ─────────────────────────────────────────────────────────────────
# Local MinIO (overridden in docker-compose)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents

# AWS S3 (used when STORAGE_BACKEND=s3 via superadmin settings)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ── DynamoDB ───────────────────────────────────────────────────────────────────
# Local DynamoDB (overridden in docker-compose)
DYNAMO_LOCAL_ENDPOINT=http://localhost:8000
DYNAMO_SESSIONS_TABLE=ChatSessions
DYNAMO_MESSAGES_TABLE=Messages

# AWS DynamoDB (used when DYNAMO_MODE=aws via superadmin settings)
AWS_DYNAMO_REGION=us-east-1

# ── Frontend ───────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173